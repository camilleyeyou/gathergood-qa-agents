# GatherGood E2E Testing Agent - Environment Configuration
#
# Copy this file to .env and fill in the values.
# Never commit the .env file.

# Target URLs (live GatherGood deployment)
BASE_URL=https://event-management-two-red.vercel.app
API_URL=https://event-management-production-ad62.up.railway.app/api/v1

# Stripe test key (optional — paid checkout tests skip without this)
STRIPE_TEST_KEY=

# Anthropic API key (required for AI agent and persona agent tests)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Railway deployment URL (optional — only needed for remote sweep triggering)
# Set after deploying the FastAPI app to Railway
RAILWAY_URL=
